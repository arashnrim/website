---
import images from "@data/images";
import { Image } from "astro:assets";
---

<section id="hero">
  <div id="hero__gallery">
    <div id="hero__gallery-text">
      <span>Scroll right for more pictures! →</span>
      <span>Hover over them, too!</span>
    </div>
    {
      images.map((image, index) => (
        <Image
          src={image.src}
          alt={image.alt}
          height={360}
          loading={index > 1 ? "lazy" : "eager"}
          format={"webp"}
          style={{ "--animation-order": index }}
          draggable={"false"}
        />
      ))
    }
  </div>

  <div id="hero__text">
    <span>Hey! I'm Arash.</span>
    <h2>
      I'm driven to craft <dfn title="in a way that feels natural"
        >intuitive</dfn
      >, <dfn title="in a way that adds meaningful value">purposeful</dfn>, and <dfn
        title="in a way that is aesthetically pleasing and usable"
        >well-designed</dfn
      > things with <dfn
        title="whether software, hardware, or anything in between">tech</dfn
      > that works for people.
    </h2>

    <a id="hero__cta" href="#connect">👋 Say hi</a>
  </div>
</section>

<script>
  import images from "@data/images";

  const imageElements: NodeListOf<HTMLImageElement> = document.querySelectorAll(
    "#hero__gallery > img",
  );
  const missionElement: HTMLHeadingElement =
    document.querySelector("#hero__text > h2")!;
  const missionHTML = missionElement.innerHTML;

  const supportsHover = window.matchMedia("(hover: hover)").matches;
  const startingEvent = supportsHover ? "mouseenter" : "click";
  const DETAILS_DURATION = 5000;
  const FADE_DURATION = 300;
  const GREETING_INTERVAL = 10000;

  let resetTimeout: NodeJS.Timeout | null = null;
  let activeImageElement: HTMLElement | null = null;

  const animateImagesOnLoad = () => {
    imageElements.forEach((imageElement) => {
      imageElement.style.opacity = "1";
      imageElement.style.animation = `1.25s ease-out calc(var(--animation-order) * 200ms) 1 present`;
      imageElement.style.animationFillMode = "backwards";
    });
  };

  const updateMissionText = (htmlContent: string) => {
    missionElement.style.opacity = "0";
    setTimeout(() => {
      missionElement.innerHTML = htmlContent;
      missionElement.style.opacity = "1";
    }, FADE_DURATION);
  };

  const resetImages = () => {
    imageElements.forEach((imageElement) => {
      imageElement.style.filter = "grayscale(100%) brightness(50%)";
    });
  };

  const handleImageInteraction = (
    imageElement: HTMLImageElement,
    index: number,
  ) => {
    if (resetTimeout) clearTimeout(resetTimeout);

    resetTimeout = setTimeout(() => {
      updateMissionText(missionHTML);
      resetImages();
    }, DETAILS_DURATION);

    if (activeImageElement) {
      activeImageElement.style.filter = "grayscale(100%) brightness(50%)";
    }

    updateMissionText(images[index].text);
    imageElement.style.filter = "grayscale(0%) brightness(100%)";
    activeImageElement = imageElement;
  };

  const rotateGreeting = () => {
    const greetings = [
      "Hey!",
      "Hello!",
      "Hi there,",
      "Hiya,",
      "Selamat datang!",
    ];
    const greetingElement: HTMLElement =
      document.querySelector("#hero__text > span")!;

    greetingElement.style.opacity = "0";
    setTimeout(() => {
      const randomGreeting =
        greetings[Math.floor(Math.random() * greetings.length)];
      greetingElement.textContent = `${randomGreeting} I'm Arash.`;
      greetingElement.style.opacity = "1";
    }, FADE_DURATION);
  };

  document.onreadystatechange = () => {
    if (document.readyState === "complete") {
      animateImagesOnLoad();
    }
  };

  if (!supportsHover) {
    const instructionElement = document.querySelector(
      "#hero__gallery-text > span:last-child",
    ) as HTMLElement;
    instructionElement.textContent = "Tap on them, too!";
  }

  imageElements.forEach((imageElement, index) => {
    imageElement.addEventListener(startingEvent, () => {
      handleImageInteraction(imageElement, index);
    });
  });

  setInterval(rotateGreeting, GREETING_INTERVAL);
</script>

<style>
  @keyframes present {
    0% {
      opacity: 0;
      transform: translateY(25px);
    }
    100% {
      opacity: 1;
    }
  }

  #hero {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow-x: scroll;
    background:
      radial-gradient(#1f1f1f, 2.5px, transparent 3px) 0 0 / 50px 50px,
      linear-gradient(to bottom, #0a0a0a, transparent 500%);
  }

  #hero__gallery {
    display: flex;
    height: 360px;
    background-color: #0a0a0a;
  }

  #hero__gallery-text {
    opacity: 0.4;
    width: fit-content;
    position: absolute;
    margin-top: 0.5em;
    margin-left: 0.5em;
    z-index: 1;
  }

  #hero__gallery-text > span {
    display: block;
  }

  #hero__gallery > img {
    height: 360px;
    filter: grayscale(100%) brightness(50%);
    transition:
      filter 0.2s ease-out,
      opacity 0.2s ease-out,
      border-radius 0.2s ease-out;
    opacity: 0;
  }

  #hero__text {
    position: sticky;
    align-content: end;
    left: calc(var(--section-padding) - 1em);
    margin: calc(var(--section-padding) - 1em);
    padding: 2em;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.5) 0%,
      rgba(10, 10, 10, 1) 75%
    );
    border-radius: var(--radius);
    animation: 0.75s ease 0s 1 present;
    background-color: #0a0a0a;
    border: 3px solid #1f1f1f;
  }

  #hero__text > span {
    font-size: var(--subtitle);
    transition: opacity 0.2s ease-in-out;
  }

  #hero__text > h2 {
    font-size: var(--title);
    margin: 0;
    transition: opacity 0.2s ease-in-out;
  }

  #hero__text > h2 > dfn {
    font-style: normal;
    cursor: help;
    text-decoration: underline dotted;
  }

  #hero__text > h2 > :global(*) {
    font-weight: inherit;
  }

  #hero__cta {
    display: block;
    width: fit-content;
    margin-top: 1em !important;
    padding: 0.25em 0.75em;
    font-size: var(--subtitle);
    background-color: transparent;
    border: 3px solid #1f1f1f;
    border-radius: 0.3em;
    transition: background-color 0.2s ease-out;
  }

  #hero__cta:hover {
    background-color: #0f0f0f;
  }

  @media only screen and (min-width: 960px) {
    #hero__text {
      max-width: 65%;
    }
  }

  @media only screen and (min-width: 1024px) {
    #hero__text {
      left: calc(var(--section-padding) / 2 - 2em);
      margin: calc(var(--section-padding) / 2 - 2em);
    }
  }

  @media only screen and (min-height: 1024px) {
    #hero {
      min-height: 100vh;
    }
  }
</style>
