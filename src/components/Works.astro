---
import projects from "@data/works";
import scrappedProjects from "@data/scrapped";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
---

<section id="works" class="container">
  <h1 class="title">Show and tell!</h1>
  <p>
    Here's a collection of my most beloved works. I believe I learn best by
    doing, so I try to pick up projects whenever I'm in the mood to learn
    something new in depth. When working on projects, I approach them with
    curiosity, patience, and determination; the result of that is projects I'm
    proud to talk about, like those below!
  </p>

  <div id="works__works-container">
    {
      projects.map((project) => {
        if (!(project.largeTile !== undefined && project.year !== undefined)) {
          throw new Error(
            "Project is missing required fields:\n" + JSON.stringify(project),
          );
        }

        return (
          <div
            class={`works__work ${
              project.largeTile ? "works__work-large" : ""
            }`}
            style={`--projectColor: ${project.backgroundColor ?? "#1f1f1f"}`}
          >
            {project.image !== undefined && (
              <Image
                class="works__work-image"
                src={project.image}
                height={640}
                quality={50}
                format="webp"
                alt={project.name}
                loading="lazy"
              />
            )}
            <div class="works__work-obstructor" />
            <div class="works__work-meta">
              {
                <span class="badge" style="--badge-color: #3d3d3d">
                  {project.year}
                </span>
              }
              {project.tech &&
                project.tech.map((lang) => (
                  <Icon name={lang.iconName} title={lang.friendlyName} />
                ))}
            </div>

            <div class="works__work-spacer" />

            <div>
              <span class="subtitle">{project.name}</span>
              <p>{project.description}</p>
            </div>

            <div class="works__work-links">
              {project.githubLink !== undefined && (
                <a
                  href={project.githubLink}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name="simple-icons:github" />
                  GitHub
                </a>
              )}
              {project.websiteLink !== undefined && (
                <a
                  href={project.websiteLink}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name="ph:globe" />
                  Website
                </a>
              )}
            </div>
          </div>
        );
      })
    }
  </div>

  <div id="works__graveyard-container">
    <div id="works__graveyard-text">
      <h2 class="subtitle">🪦 Parked projects</h2>
      <p>
        Here lies <a
          href="https://blog.arash.codes/posts/project-graveyards"
          rel="noopener noreferrer"
          target="_blank">the projects that could've been</a
        >. I hope to (re)visit these ideas when the opportunity permits, but
        feel free to have a look at making at any one of these ideas in the
        meantime if you're keen.
      </p>
    </div>

    <div id="works__graveyard-projects">
      {
        scrappedProjects.map((project) => {
          return (
            <div class="works__graveyard-project">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  #works {
    min-height: 100vh;
    box-sizing: border-box;
    background-size: 5vw 5vw;
    background-image:
      linear-gradient(to right, rgba(30, 30, 30, 0.75) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(30, 30, 30, 0.75) 1px, transparent 1px);
  }

  p {
    margin: 0;
  }

  #works__works-container {
    margin: 3rem -2em 0 -2em;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5em;
  }

  .works__work {
    display: flex;
    flex-direction: column;
    grid-column: span 2;
    background: var(--projectColor);
    border-radius: var(--radius);
    border: 3px solid var(--projectColor);
    padding: 2em;
    box-sizing: border-box;
    user-select: none;
    transition: transform 0.25s ease-out;
    position: relative;
    gap: 1em;
    overflow: hidden;
  }

  .works__work > *:not(.works__work-obstructor) {
    z-index: 1;
  }

  .works__work span.subtitle {
    font-weight: 700;
  }

  .works__work-meta {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  .works__work:hover {
    transform: translateY(-5px);
  }

  .works__work-large {
    grid-column: span 4;
  }

  .works__work-obstructor {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background-color: #0a0a0a;
    opacity: 0.3;
  }

  .works__work-spacer {
    flex: 1;
  }

  .works__work-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1em;
  }

  .works__work-links > a {
    display: flex;
    border-radius: 0.5em;
    align-items: center;
    background-color: #0a0a0a88;
    backdrop-filter: blur(0.5em);
    padding: 0.5em 1em;
    border: 0;
    flex: 1;
    gap: 0.5em;
    transition: background-color 0.2s ease;
    font-size: var(--body);
  }

  .works__work-links > a:nth-child(2) {
    background-color: #0a0a0a44;
  }

  .works__work-links > a:hover {
    background-color: #0a0a0aaa;
  }

  .works__work-links > a:hover:nth-child(2) {
    background-color: #0a0a0a66;
  }

  .works__work-links > a > svg {
    margin: 0;
  }

  .works__work-image {
    position: absolute;
    filter: grayscale(100%) opacity(0.175);
    left: 35%;
    top: 0%;
    transform: rotate(-10deg) translateY(10px);
    transform-origin: top left;
    transition:
      filter 0.3s ease-out 0.15s,
      transform 0.3s ease-out 0.15s;
  }

  .works__work-large > .works__work-image {
    left: 60%;
  }

  .works__work:hover .works__work-image {
    transform: rotate(-10deg) translateY(0);
    filter: grayscale(0%) opacity(0.65);
  }

  [data-icon] {
    height: 1.5em;
  }

  #works__graveyard-container {
    display: none;
    margin-top: 3rem;
    padding: 2em;
    border: 0.4em dashed #1f1f1f;
    overflow: scroll;
    position: relative;
    scrollbar-width: none;
    background-color: #0a0a0a;
  }

  #works__graveyard-container::-webkit-scrollbar {
    display: none;
  }

  #works__graveyard-text {
    position: sticky;
    left: 0;
  }

  #works__graveyard-projects {
    margin: 1.5em -1.95em 0 -1.95em;
    padding: 0 1.95em;
    width: fit-content;
    display: flex;
    gap: 1.5em;
    user-select: none;
  }

  .works__graveyard-project {
    padding: 1em;
    background-color: #1f1f1f;
    border: 3px solid #1f1f1f;
    min-width: 17.5vw;
    border-radius: var(--radius);
    transition:
      transform 0.25s ease-out,
      border-color 0.25s ease-out;
    overflow-y: visible;
  }

  .works__graveyard-project:hover {
    transform: translateY(-5px);
    border: 3px solid #2a2a2a;
  }

  .works__graveyard-project * {
    margin: 0;
  }

  .works__graveyard-project > h3 {
    font-size: var(--body);
  }

  @media only screen and (max-width: 360px) {
    .works__work-links {
      flex-direction: column;
    }

    .works__work-image {
      display: none;
    }
  }

  @media only screen and (max-width: 860px) {
    #works__works-container {
      grid-auto-rows: 1fr;
    }

    .works__work,
    .works__work-large {
      grid-column: span 4;
      height: 100%;
    }

    .works__work-image {
      display: none;
    }
  }

  @media only screen and (min-width: 860px) {
    .works__work {
      grid-column: span 2;
    }

    .works__work-large {
      grid-column: span 4;
    }

    #works__graveyard-container {
      display: block;
    }
  }

  @media only screen and (min-width: 1600px) {
    #works__works-container {
      grid-template-columns: repeat(4, 1fr);
      margin-left: 0;
      margin-right: 0;
      margin-bottom: 0;
    }

    .works__work {
      grid-column: span 1;
      height: 100%;
    }

    .works__work-large {
      grid-column: span 2;
      min-height: 360px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .works__work:hover,
    .works__graveyard-project:hover {
      transition: none;
    }

    .works__work:hover .works__work-image {
      transition: none;
    }
  }
</style>
